{
  "name": "unstable-ui",
  "version": "0.1.0",
  "private": true,
  "description": "React Native UI framework for agent and harness driven interfaces.",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke:packages": "npm run build && node scripts/smoke-packages.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@types/react": "^19.1.8",
    "typescript": "^5.8.3",
    "tsup": "^8.5.0"
  }
}
