{
  "name": "@selfme/unstable-ui-renderer",
  "version": "0.1.0-alpha.5",
  "description": "Default React Native renderer for the unstable-ui framework.",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.tsx",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/index.tsx",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm,cjs --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-native": ">=0.76.0"
  },
  "dependencies": {
    "@selfme/unstable-ui-core-blocks": "0.1.0-alpha.5",
    "@selfme/unstable-ui-harness-sdk": "0.1.0-alpha.5",
    "@selfme/unstable-ui-protocol": "0.1.0-alpha.5",
    "@selfme/unstable-ui-runtime": "0.1.0-alpha.5"
  }
}
